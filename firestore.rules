rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - answers: map (required) - Questionnaire answers
    //   - appState: string (required) - Current app state
    //   - isStrictCoach: bool (optional) - Strict coach mode
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // Collection: users/{uid}/logs
    // Document ID: {logId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - type: string (required) - Log type (hydration, workout, etc.)
    //   - data: map (required) - Log details
    //   - timestamp: number (required) - Unix timestamp
    //
    // Collection: users/{uid}/plans
    // Document ID: {planId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - plan: map (required) - The diet plan details
    //   - createdAt: timestamp (optional) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jaswindermehrok98@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserProfile(data) {
      return data.uid is string &&
             data.answers is map &&
             data.appState is string &&
             (!('isStrictCoach' in data) || data.isStrictCoach is bool);
    }

    function isValidLog(data) {
      return data.uid is string &&
             data.type is string &&
             data.data is map &&
             data.timestamp is number;
    }

    function isValidPlan(data) {
      return data.uid is string &&
             data.plan is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidLog(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isValidLog(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /plans/{planId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidPlan(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isValidPlan(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
